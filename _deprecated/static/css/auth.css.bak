:root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --primary-light: #3b82f6;
            --bg-gradient-start: #0f172a;
            --bg-gradient-end: #1e293b;
            --card-bg: rgba(255, 255, 255, 0.03);
            --card-border: rgba(255, 255, 255, 0.08);
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --error: #ef4444;
            --success: #22c55e;
            --google-red: #ea4335;
            --microsoft-blue: #00a4ef;
            --transition-main: all 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--bg-gradient-start) 0%, var(--bg-gradient-end) 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            color: var(--text-primary);
        }

        /* Background animation dots/glows */
        .bg-glow {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .bg-glow::before,
        .bg-glow::after {
            content: '';
            position: absolute;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.15;
            animation: float 20s ease-in-out infinite;
        }

        .bg-glow::before {
            background: var(--primary);
            top: -300px;
            left: -300px;
        }

        .bg-glow::after {
            background: #8b5cf6;
            bottom: -300px;
            right: -300px;
            animation-delay: -10s;
        }

        @keyframes float {

            0%,
            100% {
                transform: translate(0, 0) scale(1);
            }

            50% {
                transform: translate(50px, 30px) scale(1.1);
            }
        }

        .auth-wrapper {
            position: relative;
            z-index: 1;
            width: 1000px;
            max-width: 95vw;
            height: 650px;
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 24px;
            backdrop-filter: blur(20px);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            display: flex;
            overflow: hidden;
            margin: 20px 0;
        }

        /* Forms Container */
        .forms-container {
            position: absolute;
            top: 0;
            width: 50%;
            height: 100%;
            transition: var(--transition-main);
            z-index: 10;
        }

        .login-side {
            left: 0;
        }

        .signup-side {
            left: 0;
            opacity: 0;
            pointer-events: none;
        }

        /* Overlay Container */
        .overlay-container {
            position: absolute;
            top: 0;
            left: 50%;
            width: 50%;
            height: 100%;
            overflow: hidden;
            transition: var(--transition-main);
            z-index: 20;
            border-left: 1px solid var(--card-border);
        }

        .overlay {
            background: url('/static/brain/auth_branding_image_signin.png') no-repeat center center;
            background-size: cover;
            width: 100%;
            height: 100%;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 40px;
        }

        .overlay::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.5) 0%, rgba(37, 99, 235, 0.3) 100%);
            backdrop-filter: brightness(0.8);
        }

        .overlay-content {
            position: relative;
            z-index: 30;
            color: white;
        }

        .overlay h2 {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 1rem;
            text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
        }

        .overlay p {
            font-size: 1rem;
            opacity: 0.9;
            line-height: 1.6;
            margin-bottom: 2rem;
        }

        /* Sliding classes */
        .auth-wrapper.active-signup .forms-container {
            transform: translateX(100%);
        }

        .auth-wrapper.active-signup .overlay-container {
            transform: translateX(-100%);
            border-left: none;
            border-right: 1px solid var(--card-border);
        }

        .auth-wrapper.active-signup .login-side {
            opacity: 0;
            pointer-events: none;
        }

        .auth-wrapper.active-signup .signup-side {
            opacity: 1;
            pointer-events: all;
        }

        /* Form styling */
        .form-box {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 100%;
            padding: 50px 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            transition: opacity 0.4s ease;
        }

        .app-icon {
            width: 50px;
            height: 50px;
            background: linear-gradient(135deg, #007AFF 0%, #0051D5 100%);
            border-radius: 14px;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 10px 30px rgba(0, 122, 255, 0.3), 0 4px 15px rgba(0, 0, 0, 0.1);
            position: relative;
            overflow: hidden;
            margin: 0 auto 20px auto;
        }

        .form-header {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            margin-bottom: 5px;
        }

        .icon-svg {
            color: white;
        }

        h1 {
            font-size: 1.75rem;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .subtitle {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-bottom: 10px;
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

        label {
            display: block;
            margin-bottom: 6px;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text-secondary);
        }

        input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            color: var(--text-primary);
            font-size: 0.95rem;
            transition: all 0.2s;
        }

        input:focus {
            outline: none;
            border-color: var(--primary);
            background: rgba(255, 255, 255, 0.08);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        }

        input::placeholder {
            color: var(--text-muted);
        }

        .form-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            font-size: 0.85rem;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-secondary);
            cursor: pointer;
        }

        .checkbox-group input {
            width: 18px;
            height: 18px;
            accent-color: var(--primary);
            cursor: pointer;
        }

        .forgot-link,
        .toggle-link {
            color: var(--primary-light);
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
        }

        .forgot-link:hover,
        .toggle-link:hover {
            text-decoration: underline;
        }

        .btn-primary {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            margin-bottom: 20px;
        }

        .btn-primary:hover:not(.btn-outline) {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px -5px rgba(37, 99, 235, 0.5);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid white;
            width: auto;
            padding: 12px 30px;
        }

        .btn-outline:hover {
            background: rgba(255, 255, 255, 0.1);
            transform: scale(1.05);
        }

        .divider {
            position: relative;
            text-align: center;
            margin: 15px 0;
        }

        .divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            width: 100%;
            height: 1px;
            background: var(--card-border);
        }

        .divider span {
            position: relative;
            background: #161e32;
            padding: 0 10px;
            color: var(--text-muted);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .oauth-group {
            display: flex;
            gap: 12px;
        }

        .btn-oauth {
            flex: 1;
            padding: 10px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            color: var(--text-primary);
        }

        .btn-oauth:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--text-muted);
        }

        .btn-oauth svg {
            width: 18px;
            height: 18px;
        }

        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 16px 24px;
            border-radius: 12px;
            color: white;
            font-weight: 500;
            z-index: 1000;
            transform: translateX(120%);
            transition: transform 0.3s ease;
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
        }

        .notification.show {
            transform: translateX(0);
        }

        .notification-success {
            background: var(--success);
        }

        .notification-error {
            background: var(--error);
        }

        @media (max-width: 800px) {
            .auth-wrapper {
                height: auto;
                flex-direction: column;
                max-width: 450px;
                overflow-y: auto;
            }

            .forms-container {
                position: relative;
                width: 100%;
                height: 600px;
                order: 2;
                transform: none !important;
            }

            .overlay-container {
                position: relative;
                width: 100%;
                height: 200px;
                left: 0;
                order: 1;
                transform: none !important;
                border-left: none;
                border-bottom: 1px solid var(--card-border);
            }

            .overlay h2 {
                font-size: 1.5rem;
            }

            .overlay p,
            .overlay button {
                display: none;
            }

            .form-box {
                padding: 30px 40px;
            }
        }
